{
  "name": "video-bubble-onboarding",
  "version": "0.1.0",
  "description": "Floating video-bubble product tours that spotlight your UI in sync with a narrated clip. Framework-agnostic React, zero backend at runtime.",
  "license": "MIT",
  "type": "module",
  "sideEffects": [
    "*.css"
  ],
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./styles.css": "./src/styles.css"
  },
  "files": [
    "src",
    "README.md",
    "LICENSE"
  ],
  "peerDependencies": {
    "react": ">=17",
    "react-dom": ">=17"
  },
  "keywords": [
    "onboarding",
    "product-tour",
    "walkthrough",
    "react",
    "video",
    "tooltip",
    "spotlight"
  ]
}
